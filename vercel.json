{
  "version": 2,
  "regions": ["sfo1"],
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    { "src": "api/state.py", "use": "@vercel/python" },
    { "src": "*.html", "use": "@vercel/static" }
  ],
  "rewrites": [
    { "source": "/api/state", "destination": "/api/state.py" },
    { "source": "/app", "destination": "/index.html" },
    { "source": "/", "destination": "/intro.html" },
    { "source": "/(.*)", "destination": "/intro.html" }
  ]
}
