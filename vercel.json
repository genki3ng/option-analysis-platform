{
  "version": 2,
  "regions": ["sfo1"],
  "builds": [
    { "src": "api/state.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "intro.html", "use": "@vercel/static" },
    { "src": "marks.html", "use": "@vercel/static" },
    { "src": "buttons.html", "use": "@vercel/static" },
    { "src": "positions-preview.html", "use": "@vercel/static" },
    { "src": "rec-redesign.html", "use": "@vercel/static" },
    { "src": "form-dual-preview.html", "use": "@vercel/static" },
    { "src": "recommend-cta.html", "use": "@vercel/static" },
    { "src": "account-modal-preview.html", "use": "@vercel/static" },
    { "src": "iphone-text.html", "use": "@vercel/static" },
    { "src": "admin.html", "use": "@vercel/static" },
    { "src": "v2-ladder.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/state", "dest": "/api/state.py" },
    { "src": "/app/?", "dest": "/index.html" },
    { "src": "/marks/?", "dest": "/marks.html" },
    { "src": "/buttons/?", "dest": "/buttons.html" },
    { "src": "/positions-preview/?", "dest": "/positions-preview.html" },
    { "src": "/rec-redesign/?", "dest": "/rec-redesign.html" },
    { "src": "/form-dual-preview/?", "dest": "/form-dual-preview.html" },
    { "src": "/recommend-cta/?", "dest": "/recommend-cta.html" },
    { "src": "/account-modal-preview/?", "dest": "/account-modal-preview.html" },
    { "src": "/iphone-text/?", "dest": "/iphone-text.html" },
    { "src": "/admin/?", "dest": "/admin.html" },
    { "src": "/v2-ladder/?", "dest": "/v2-ladder.html" },
    { "src": "/(.*)", "dest": "/intro.html" }
  ]
}
